{
  "input_window": 12,
  "output_window": 12,
  "hidden_dim": 128,
  "num_heads": 4,
  "encoder_layers": 2,
  "denoiser_layers": 4,
  "ffn_hidden_dim": 256,
  "graph_k_hop": 2,
  "use_adaptive_graph": true,
  "adaptive_graph_embed_dim": 32,
  "adaptive_graph_topk": 20,
  "adaptive_graph_blend_init": 0.5,
  "use_spatiotemporal_attention": true,
  "use_temporal_position_embedding": true,
  "use_gradient_checkpointing": true,
  "use_amp": true,
  "amp_dtype": "float16",
  "dropout": 0.1,
  "diffusion_steps": 200,
  "diffusion_schedule": "linear",
  "beta_start": 0.0001,
  "beta_end": 0.02,
  "num_sampling_steps": 200,
  "num_prediction_samples": 4,
  "sampling_method": "ddpm",
  "ddim_eta": 0.0,
  "physics_loss_weight": 0.05,
  "flow_conservation_coeff": 1.0,
  "physics_channel_idx": 0,
  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "add_time_in_day": false,
  "add_day_in_week": false,
  "max_epoch": 50,
  "learner": "adamw",
  "learning_rate": 0.001,
  "lr_decay": true,
  "weight_decay": 0.0001,
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 20,
  "batch_size": 32,
  "eval_batch_size": 32,
  "steps": [20, 35],
  "lr_decay_ratio": 0.5
}
